# Counterpoint backend (server/) configuration.
# Copy to ".env" and adjust. All values have safe defaults.

# --- Local LLM (OpenAI-compatible) -------------------------------------------
# Base URL of your local model server's OpenAI-compatible API.
#   LM Studio : http://localhost:1234/v1
#   Ollama    : http://localhost:11434/v1
#   llama.cpp : http://localhost:8080/v1
AI_BASE_URL=http://localhost:1234/v1
# Model name as your runtime reports it (LM Studio: the loaded model id;
# Ollama: e.g. "llama3.1" or "qwen2.5").
AI_MODEL=local-model
# Most local runtimes ignore the key, but the OpenAI client requires one.
AI_API_KEY=not-needed

# --- Enrichment tuning -------------------------------------------------------
AI_BATCH_SIZE=8        # items classified per LLM request
AI_CONCURRENCY=2       # parallel LLM requests (keep low for local GPUs)
AI_MAX_ITEMS=80        # cap items sent to the LLM per refresh (cost/latency)
AI_TIMEOUT_MS=60000    # per-request timeout for the LLM

# --- Server ------------------------------------------------------------------
PORT=8787
FEED_TTL_MS=600000     # serve cached feed for 10 min before re-fetching/enriching
