# Counterpoint backend (server/) configuration.
# Copy to ".env" and adjust. All values have safe defaults.

# --- Local LLM (OpenAI-compatible) -------------------------------------------
# Base URL of your local model server's OpenAI-compatible API.
#   LM Studio : http://localhost:1234/v1
#   Ollama    : http://localhost:11434/v1
#   llama.cpp : http://localhost:8080/v1
AI_BASE_URL=http://localhost:1234/v1
# Model name as your runtime reports it (LM Studio: the loaded model id;
# Ollama: e.g. "llama3.1" or "qwen2.5").
AI_MODEL=local-model
# Most local runtimes ignore the key, but the OpenAI client requires one.
AI_API_KEY=not-needed

# --- Analysis tuning ---------------------------------------------------------
AI_BATCH_SIZE=8          # items per deep-analysis LLM request
AI_TRIAGE_BATCH_SIZE=40  # headlines per cheap clickbait-triage request
AI_CONCURRENCY=2         # parallel LLM requests (keep low for local GPUs)
AI_MAX_ITEMS=24          # items deeply analyzed per CHUNK — small so the feed synthesizes in seconds (rest drained in background); 0 = one big pass
AI_TIMEOUT_MS=120000     # LLM INACTIVITY timeout (resets while streaming); raise on slow GPUs
# CLICKBAIT_FILTER_OFF=1 # disable the clickbait/junk triage pass
# AI_STRUCTURED_OUTPUT_OFF=1 # disable JSON-schema constrained decoding (only if your runtime rejects response_format)

# --- Semantic search (embeddings) --------------------------------------------
# Match a search by MEANING (cosine similarity) instead of keywords. Each item
# is embedded once (cached in the store); searches embed once (cached in memory).
# Requires an embedding model loaded in your runtime (POST /v1/embeddings).
# Falls back automatically to keyword matching if unavailable.
AI_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5  # your loaded embedding model id
AI_EMBED_BATCH_SIZE=32   # texts per embeddings request
# AI_EMBEDDINGS_OFF=1    # disable semantic matching (keyword-only)

# --- Analysis store (persisted so restarts/interest changes are fast) --------
# FEED_STORE_PATH=.cache/feed-store.json   # where analyzed items are cached
# FEED_RETENTION_MS=1209600000             # drop analyzed items older than 14d
# FEED_MAX_STORED=8000                     # hard cap on stored items
# FEED_ANALYZE_MAX_AGE_MS=259200000        # only analyze items newer than this (3d) — keeps first run tractable
# FEED_CATCHUP_DELAY_MS=1500               # gap between background analysis chunks
# FEED_PRESCREEN_CHUNK=40                   # headlines triaged per chunk; cold start waits only on the first (0 = one big pass)

# --- In-app AI reader (the "Read in app" button) -----------------------------
# READER_MIN_CHARS=600        # min extracted chars before we attempt a rewrite (else paywall/JS-only)
# READER_MAX_CHARS=12000      # max article chars sent to the model
# READER_MAX_TOKENS=2200      # cap on the rewrite reply length
# READER_CACHE_TTL_MS=21600000 # how long a rewritten article is cached in memory (6h)
# Fallbacks when a page can't be read directly (bot-walls / JS-only / paywalls):
# READER_PROXY_OFF=1          # don't retry via reader proxies (r.jina.ai/CORS). Helps JS pages + some soft paywalls; does NOT bypass hard paywalls. Adds a 3rd-party request per fallback.
# READER_JINA_API_KEY=jina_xxx # r.jina.ai API key. The free/anonymous tier now rate-limits & captcha-gates (HTTP 403); an authenticated request restores reliable access. Get one at https://jina.ai/reader
# READER_DEGRADED_OFF=1       # don't synthesize a labeled short brief from the headline+summary when no full body is available (show error + Open original instead)

# --- YouTube transcripts (via yt-dlp) ----------------------------------------
# The backend uses yt-dlp to fetch YouTube caption transcripts so the model
# understands a video's actual content, not just its description. Requires
# yt-dlp on PATH ("brew install yt-dlp" or "python3 -m pip install -U yt-dlp").
# Degrades gracefully (description-only) if yt-dlp is missing.
# TRANSCRIPTS_OFF=1            # disable transcript fetching entirely
# YT_DLP_PATH=yt-dlp          # path/command for the yt-dlp binary
TRANSCRIPT_MAX_CHARS=6000     # max transcript chars sent to the model
TRANSCRIPT_CONCURRENCY=2      # parallel yt-dlp processes
TRANSCRIPT_TIMEOUT_MS=30000   # per-video timeout for yt-dlp

# --- Server ------------------------------------------------------------------
PORT=8787
FEED_TTL_MS=600000     # serve cached feed for 10 min before re-fetching/enriching
# FEED_INTEREST=AI and AI-related scientific progress   # default steering interest

# --- Web client -> backend URL (EXPO_PUBLIC_* are inlined into the web build) -
# By default the web app calls the backend on the SAME host it was loaded from,
# on the port below — so opening http://tfvr.ddns.net:8081 talks to
# http://tfvr.ddns.net:8787 automatically (forward/expose BOTH ports).
# EXPO_PUBLIC_API_PORT=8787
# Or hard-pin the backend origin (overrides the auto-detection above):
# EXPO_PUBLIC_API_URL=http://tfvr.ddns.net:8787

# --- Corporate TLS interception (Zscaler/Netskope/etc.) ----------------------
# If feed fetches fail with SELF_SIGNED_CERT_IN_CHAIN, Node doesn't trust your
# corporate root CA (your browser does). Pick ONE:
#   SECURE  (recommended): point Node at your corporate root CA bundle.
# NODE_EXTRA_CA_CERTS=/path/to/corporate-root-ca.pem
#   DEV-ONLY: disable TLS verification entirely (insecure; local use only).
# ALLOW_INSECURE_TLS=1
