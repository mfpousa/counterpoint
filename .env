# Counterpoint backend (server/) configuration.
# Copy to ".env" and adjust. All values have safe defaults.

# --- Local LLM (OpenAI-compatible) -------------------------------------------
# Base URL of your local model server's OpenAI-compatible API.
#   LM Studio : http://localhost:1234/v1
#   Ollama    : http://localhost:11434/v1
#   llama.cpp : http://localhost:8080/v1
AI_BASE_URL=http://localhost:1234/v1
# Model name as your runtime reports it (LM Studio: the loaded model id;
# Ollama: e.g. "llama3.1" or "qwen2.5").
# AI_MODEL=qwen/qwen3.5-9b
AI_MODEL=google/gemma-4-12b-qat
# AI_MODEL=openai/gpt-oss-20b
AI_EMBED_MODEL=ggml-org/embeddinggemma-300M-GGUF

# Most local runtimes ignore the key, but the OpenAI client requires one.
AI_API_KEY=not-needed

# --- Enrichment tuning -------------------------------------------------------
AI_BATCH_SIZE=8        # items classified per LLM request
AI_CONCURRENCY=2       # parallel LLM requests (keep low for local GPUs)
AI_MAX_ITEMS=80        # cap items sent to the LLM per refresh (cost/latency)
AI_TIMEOUT_MS=60000    # per-request timeout for the LLM

# --- YouTube transcripts (via yt-dlp) ----------------------------------------
# The backend uses yt-dlp to fetch YouTube caption transcripts so the model
# understands a video's actual content, not just its description. Requires
# yt-dlp on PATH ("brew install yt-dlp" or "python3 -m pip install -U yt-dlp").
# Degrades gracefully (description-only) if yt-dlp is missing.
# TRANSCRIPTS_OFF=1            # disable transcript fetching entirely
# YT_DLP_PATH=yt-dlp          # path/command for the yt-dlp binary
TRANSCRIPT_MAX_CHARS=6000     # max transcript chars sent to the model
TRANSCRIPT_CONCURRENCY=2      # parallel yt-dlp processes
TRANSCRIPT_TIMEOUT_MS=30000   # per-video timeout for yt-dlp

# --- Server ------------------------------------------------------------------
PORT=8787
FEED_TTL_MS=600000     # serve cached feed for 10 min before re-fetching/enriching

# --- Corporate TLS interception (Zscaler/Netskope/etc.) ----------------------
# If feed fetches fail with SELF_SIGNED_CERT_IN_CHAIN, Node doesn't trust your
# corporate root CA (your browser does). Pick ONE:
#   SECURE  (recommended): point Node at your corporate root CA bundle.
# NODE_EXTRA_CA_CERTS=/path/to/corporate-root-ca.pem
#   DEV-ONLY: disable TLS verification entirely (insecure; local use only).
# ALLOW_INSECURE_TLS=1
